{
  "$schema": "https://raw.githubusercontent.com/aspect-build/aspect/main/aspect-cli.json",
  "productName": "MD Editor",
  "version": "0.1.0",
  "identifier": "com.mdeditor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MD Editor",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "scope": ["**"]
    },
    "dialog": {
      "scope": true
    },
    "clipboard-manager": {
      "scope": ["read", "write"]
    }
  }
}
